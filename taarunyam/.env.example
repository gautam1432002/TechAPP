# ─── API Configuration ────────────────────────────────────────────────────────
# Base URL for the Django backend API
VITE_API_BASE_URL=http://localhost:8000

# ─── App Configuration ────────────────────────────────────────────────────────
# Public domain used in QR code generation for verify links
VITE_SITE_DOMAIN=https://taarunyam.com

# ─── Development Flags ────────────────────────────────────────────────────────
# Set to 'true' to use the local fallback data if the API is offline
VITE_USE_MOCK=false
